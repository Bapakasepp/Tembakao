<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AGROTA Store</title>
  <style>
    * { box-sizing: border-box; margin: 0; font-family: Arial, sans-serif; }
    body { background: #f5f5f5; }
    header {
      background: #111;
      color: white;
      padding: 15px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo { font-size: 20px; font-weight: bold; }
    .cart { cursor: pointer; }

    .container { padding: 20px; }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      transition: 0.3s;
    }

    .card:hover { transform: translateY(-5px); }

    .card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    .card-body { padding: 15px; }

    .title { font-size: 16px; margin-bottom: 5px; }
    .price { color: #27ae60; margin-bottom: 10px; }

    button {
      width: 100%;
      padding: 10px;
      border: none;
      background: #111;
      color: white;
      border-radius: 8px;
      cursor: pointer;
    }

    button:hover { background: #333; }

    /* Cart Modal */
    .modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.5);
      display: none;
      justify-content: center;
      align-items: center;
    }

    .modal-content {
      background: white;
      padding: 20px;
      border-radius: 12px;
      width: 90%;
      max-width: 400px;
    }

    .close { float: right; cursor: pointer; }

    @media (max-width: 600px) {
      header { flex-direction: column; gap: 10px; }
    }
  </style>
</head>
<body>

<header>
  <div class="logo">AGROTA Store</div>
  <div class="cart" onclick="openCart()">🛒 Cart (<span id="cart-count">0</span>)</div>
</header>

<div class="container">
  <div class="grid" id="product-list"></div>
</div>

<!-- Cart Modal -->
<div class="modal" id="cart-modal">
  <div class="modal-content">
    <span class="close" onclick="closeCart()">&times;</span>
    <h3>Keranjang</h3>
    <ul id="cart-items"></ul>
    <p><strong>Total: Rp <span id="total">0</span></strong></p>
    <button onclick="checkout()">Checkout</button>
  </div>
</div>

<script>
    function formatRupiah(angka) {
  return new Intl.NumberFormat("id-ID", {
    style: "currency",
    currency: "IDR",
    minimumFractionDigits: 0
  }).format(angka);
}

const products = [
  { id: 1, name: "Baju Retro", price: 150000, image: "https://i.pinimg.com/1200x/ac/89/23/ac892342d57dc17e79012bc364c8b15b.jpg" },
  { id: 2, name: "Hoodie Gun", price: 90000, image: "https://i.pinimg.com/1200x/41/fc/3f/41fc3f5f4482ec2647a8f76f69a2078e.jpg" },
  { id: 3, name: "Hoodie Fire", price: 300000, image: "https://i.pinimg.com/736x/d4/68/d5/d468d5b5148f70a2cb0d909ba9d23d1f.jpg" },
  { id: 4, name: "Hoodie Hand God", price: 200000, image: "https://i.pinimg.com/1200x/51/4c/93/514c9375eb24ba26d52fab235f5f5b7c.jpg" },
  { id: 5, name: "Hoodie Skull Eye", price: 280000, image: "https://i.pinimg.com/1200x/e0/e5/0d/e0e50dcde138bbc0a732579948578953.jpg" },
  { id: 6, name: "Hooide Skull baret", price: 560000, image: "https://i.pinimg.com/736x/e1/a3/19/e1a319278f1de61e24128b644c12ca95.jpg" },
  { id: 7, name: "Hoodie Skull Bone", price: 900000, image: "https://i.pinimg.com/736x/d8/60/8d/d8608d7104eae4a5f5c6b9abe5149526.jpg" },
  { id: 8, name: "Hoodie Skull Sea", price: 300000, image: "https://i.pinimg.com/736x/2e/e6/f4/2ee6f4634b153641b94c6c26f27cfdd0.jpg" },
  { id: 9, name: "Hoodie Abstract", price: 450000, image: "https://i.pinimg.com/1200x/54/ff/c5/54ffc581aeb534d1c78760a73932d710.jpg" },
  { id: 10, name: "Hoodie Cyber", price: 760000, image: "https://i.pinimg.com/736x/4b/bc/32/4bbc32f20c876dbbc63ab2eb70638b47.jpg" },
  { id: 11, name: "Crewneck Abstarct", price: 620000, image: "https://i.pinimg.com/736x/24/22/b1/2422b11addc991ec0d80f23c5eadc0aa.jpg" },
  { id: 12, name: "Crewneck Cyber", price: 390000, image: "https://i.pinimg.com/736x/9e/d5/5b/9ed55ba70993f9b3402496c3b80e1a64.jpg" },
];

let cart = [];

function renderProducts() {
  const container = document.getElementById("product-list");
  container.innerHTML = "";

  products.forEach(p => {
    container.innerHTML += `
      <div class="card">
        <img src="${p.image}" />
        <div class="card-body">
          <div class="title">${p.name}</div>
          <div class="price">Rp ${p.price}</div>
          <button onclick="addToCart(${p.id})">Tambah</button>
        </div>
      </div>
    `;
  });
}

function addToCart(id) {
  const item = products.find(p => p.id === id);
  cart.push(item);
  updateCart();
}

function updateCart() {
  document.getElementById("cart-count").innerText = cart.length;

  const list = document.getElementById("cart-items");
  list.innerHTML = "";

  let total = 0;

  cart.forEach(item => {
    total += item.price;
    list.innerHTML += `<li>${item.name} - Rp ${item.price}</li>`;
  });

  document.getElementById("total").innerText = total;
}

function openCart() {
  document.getElementById("cart-modal").style.display = "flex";
}

function closeCart() {
  document.getElementById("cart-modal").style.display = "none";
}

function checkout() {
  alert("Pembayaran berhasil! 🎉");
  cart = [];
  updateCart();
  closeCart();
}

renderProducts();
</script>

</body>
</html>
